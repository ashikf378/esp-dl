// =================== SIMPLE RGB565 RESIZER (QVGA -> 224x224) ===================
static void resize_rgb565(const uint16_t *src, int src_w, int src_h, uint16_t *dst, int dst_w, int dst_h)
{
    float x_ratio = (float)src_w / dst_w;
    float y_ratio = (float)src_h / dst_h;
    for (int y = 0; y < dst_h; y++) {
        int src_y = (int)(y * y_ratio);
        const uint16_t *src_row = src + src_y * src_w;
        uint16_t *dst_row = dst + y * dst_w;
        for (int x = 0; x < dst_w; x++) {
            int src_x = (int)(x * x_ratio);
            dst_row[x] = src_row[src_x];
        }
    }
}

// =================== MAIN APPLICATION ===================
extern "C" void app_main(void)
{
#if CONFIG_HAND_DETECT_MODEL_IN_SDCARD || CONFIG_HAND_GESTURE_CLS_MODEL_IN_SDCARD
    ESP_ERROR_CHECK(bsp_sdcard_mount());
#endif

    // Initialize LCD
    lcd_init();

    // Allocate DMA‑capable buffer for LCD (internal SRAM)
    lcd_dma_buffer = (uint16_t *)heap_caps_malloc(LCD_H_RES * LCD_V_RES * sizeof(uint16_t), MALLOC_CAP_DMA);
    if (!lcd_dma_buffer) {
        ESP_LOGE(TAG, "Failed to allocate DMA buffer for LCD");
        return;
    }

    // Show a red screen test to verify LCD
    for (int i = 0; i < LCD_H_RES * LCD_V_RES; i++) lcd_dma_buffer[i] = 0xF800; // red
    esp_lcd_panel_draw_bitmap(panel_handle, 0, 0, LCD_H_RES, LCD_V_RES, lcd_dma_buffer);
    vTaskDelay(pdMS_TO_TICKS(1000));

    // Initialize camera
    esp_err_t err = esp_camera_init(&camera_config);
    if (err != ESP_OK) {
        ESP_LOGE(TAG, "Camera init failed: 0x%x", err);
        return;
    }
    ESP_LOGI(TAG, "Camera initialized");

    // Tune camera
    sensor_t *s = esp_camera_sensor_get();
    if (s) {
        s->set_vflip(s, 1);
        s->set_contrast(s, 1);
        s->set_brightness(s, 1);
        s->set_whitebal(s, 1);
        s->set_exposure_ctrl(s, 1);
        s->set_gain_ctrl(s, 1);
        s->set_awb_gain(s, 1);
        s->set_sharpness(s, 1);
        ESP_LOGI(TAG, "Camera sensor tuned");
    }

    // Hand detection model (224x224 input)
    HandDetect *hand_detect = new HandDetect(HandDetect::model_type_t::ESPDET_PICO_224_224_HAND);
    hand_detect->set_score_thr(0.3f);
    hand_detect->set_nms_thr(0.45f);

    // Gesture recognizer
    HandGestureRecognizer *hand_gesture_recognizer = new HandGestureRecognizer(HandGestureCls::MOBILENETV2_0_5_S8_V1);

    // Resize buffer (224x224) – stays in PSRAM, no DMA needed for detection
    const int DETECT_W = 224, DETECT_H = 224;
    uint16_t *resize_buf = (uint16_t *)heap_caps_malloc(DETECT_W * DETECT_H * sizeof(uint16_t), MALLOC_CAP_SPIRAM);
    if (!resize_buf) {
        ESP_LOGE(TAG, "Failed to allocate resize buffer");
        return;
    }

    while (1) {
        camera_fb_t *fb = esp_camera_fb_get();
        if (!fb) {
            ESP_LOGE(TAG, "Frame capture failed");
            vTaskDelay(pdMS_TO_TICKS(10));
            continue;
        }

        if (fb->width != 320 || fb->height != 240 || fb->format != PIXFORMAT_RGB565) {
            ESP_LOGW(TAG, "Unexpected frame format/size");
            esp_camera_fb_return(fb);
            vTaskDelay(pdMS_TO_TICKS(10));
            continue;
        }

        // Copy camera frame to DMA‑capable buffer
        memcpy(lcd_dma_buffer, fb->buf, LCD_H_RES * LCD_V_RES * sizeof(uint16_t));

        // Resize to 224x224 for detection (using the original PSRAM buffer)
        resize_rgb565((uint16_t *)fb->buf, fb->width, fb->height, resize_buf, DETECT_W, DETECT_H);

        dl::image::img_t detect_img;
        detect_img.data = (uint8_t *)resize_buf;
        detect_img.width = DETECT_W;
        detect_img.height = DETECT_H;
        detect_img.pix_type = dl::image::DL_IMAGE_PIX_TYPE_RGB565;

        // Run hand detection
        std::list<dl::detect::result_t> detections = hand_detect->run(detect_img);

        // Scale boxes back to QVGA coordinates
        float scale_x = (float)fb->width / DETECT_W;
        float scale_y = (float)fb->height / DETECT_H;
        for (auto &res : detections) {
            res.box[0] = (int)(res.box[0] * scale_x);
            res.box[1] = (int)(res.box[1] * scale_y);
            res.box[2] = (int)(res.box[2] * scale_x);
            res.box[3] = (int)(res.box[3] * scale_y);
        }

        // Recognize gestures using original full frame (still in PSRAM, but that's fine for the recognizer)
        dl::image::img_t full_img;
        full_img.data = fb->buf;
        full_img.width = fb->width;
        full_img.height = fb->height;
        full_img.pix_type = dl::image::DL_IMAGE_PIX_TYPE_RGB565;

        std::vector<dl::cls::result_t> results = hand_gesture_recognizer->recognize(full_img, detections);

        // ----- DRAW ON DMA BUFFER (not directly on fb->buf) -----
        const uint16_t BOX_COLOR = 0xF800; // red
        const uint16_t TEXT_BG = 0x0000;   // black
        const uint16_t TEXT_FG = 0xFFFF;   // white

        // Draw all detection boxes
        for (const auto &res : detections) {
            draw_box(lcd_dma_buffer, fb->width, fb->height, res.box[0], res.box[1], res.box[2], res.box[3], BOX_COLOR);
        }

        // Draw gesture results
        int text_y = 10;
        for (size_t i = 0; i < results.size() && i < detections.size(); i++) {
            const auto &res = results[i];
            char text_buf[32];
            snprintf(text_buf, sizeof(text_buf), "%s (%.2f)", res.cat_name, res.score);
            int text_w = 6 * strlen(text_buf);
            // Draw background rectangle
            for (int dy = 0; dy < 12; dy++) {
                for (int dx = 0; dx < text_w; dx++) {
                    if (dx < fb->width && text_y + dy < fb->height)
                        lcd_dma_buffer[(text_y + dy) * fb->width + dx] = TEXT_BG;
                }
            }
            draw_text(lcd_dma_buffer, fb->width, fb->height, 2, text_y, text_buf, TEXT_FG, TEXT_BG);
            text_y += 14;
        }

        // Send the DMA‑capable buffer to the LCD
        esp_lcd_panel_draw_bitmap(panel_handle, 0, 0, LCD_H_RES, LCD_V_RES, lcd_dma_buffer);

        // Logging
        if (!results.empty()) {
            for (const auto &res : results) {
                ESP_LOGI(TAG, "Gesture: %s (%.3f)", res.cat_name, res.score);
            }
        } else {
            ESP_LOGD(TAG, "No gesture recognized");
        }

        esp_camera_fb_return(fb);
        vTaskDelay(pdMS_TO_TICKS(30)); // ~30 FPS
    }

    // Cleanup (never reached)
    free(resize_buf);
    free(lcd_dma_buffer);
    delete hand_detect;
    delete hand_gesture_recognizer;
    esp_camera_deinit();

#if CONFIG_HAND_DETECT_MODEL_IN_SDCARD || CONFIG_HAND_GESTURE_CLS_MODEL_IN_SDCARD
    ESP_ERROR_CHECK(bsp_sdcard_unmount());
#endif
}
