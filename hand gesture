// =================== BACKLIGHT PWM INIT (using TIMER1/CHANNEL1 to avoid camera conflict) ===================
static void backlight_pwm_init(void)
{
    bool active_low = true;

    // Timer configuration (use TIMER_1)
    ledc_timer_config_t ledc_timer = {};
    ledc_timer.speed_mode = LEDC_LOW_SPEED_MODE;
    ledc_timer.duty_resolution = LEDC_TIMER_8_BIT;
    ledc_timer.timer_num = LEDC_TIMER_1;
    ledc_timer.freq_hz = 5000;
    ledc_timer.clk_cfg = LEDC_AUTO_CLK;
    ESP_ERROR_CHECK(ledc_timer_config(&ledc_timer));

    // Channel configuration (use CHANNEL_1)
    ledc_channel_config_t ledc_channel = {};
    ledc_channel.gpio_num = BSP_LCD_BACKLIGHT;
    ledc_channel.speed_mode = LEDC_LOW_SPEED_MODE;
    ledc_channel.channel = LEDC_CHANNEL_1;
    ledc_channel.intr_type = LEDC_INTR_DISABLE;
    ledc_channel.timer_sel = LEDC_TIMER_1;
    ledc_channel.duty = (uint32_t)(active_low ? 0 : 255);
    ledc_channel.hpoint = 0;

    esp_err_t ret = ledc_channel_config(&ledc_channel);
    if (ret != ESP_OK) {
        ESP_LOGW(TAG, "PWM backlight failed, falling back to GPIO high");
        gpio_set_direction(BSP_LCD_BACKLIGHT, GPIO_MODE_OUTPUT);
        gpio_set_level(BSP_LCD_BACKLIGHT, 1);
    } else {
        ESP_LOGI(TAG, "Backlight PWM enabled");
        ledc_set_duty(LEDC_LOW_SPEED_MODE, LEDC_CHANNEL_1, ledc_channel.duty);
        ledc_update_duty(LEDC_LOW_SPEED_MODE, LEDC_CHANNEL_1);
    }
}

// =================== LCD INITIALIZATION ===================
static void lcd_init(void)
{
    // SPI bus configuration
    spi_bus_config_t buscfg = {};
    buscfg.sclk_io_num = BSP_LCD_SPI_CLK;
    buscfg.mosi_io_num = BSP_LCD_SPI_MOSI;
    buscfg.miso_io_num = -1;
    buscfg.max_transfer_sz = LCD_H_RES * LCD_V_RES * 2;
    ESP_ERROR_CHECK(spi_bus_initialize(SPI3_HOST, &buscfg, SPI_DMA_CH_AUTO));

    // LCD IO configuration
    esp_lcd_panel_io_spi_config_t io_config = {};
    io_config.dc_gpio_num = BSP_LCD_DC;
    io_config.cs_gpio_num = BSP_LCD_CS;
    io_config.pclk_hz = 20 * 1000 * 1000; // 20 MHz
    io_config.lcd_cmd_bits = 8;
    io_config.lcd_param_bits = 8;
    io_config.spi_mode = 0;
    io_config.trans_queue_depth = 10;

    esp_lcd_panel_io_handle_t io_handle = NULL;
    ESP_ERROR_CHECK(esp_lcd_new_panel_io_spi(SPI3_HOST, &io_config, &io_handle));

    // Hardware reset if needed
    if (BSP_LCD_RST != GPIO_NUM_NC) {
        gpio_set_direction(BSP_LCD_RST, GPIO_MODE_OUTPUT);
        gpio_set_level(BSP_LCD_RST, 0);
        vTaskDelay(pdMS_TO_TICKS(10));
        gpio_set_level(BSP_LCD_RST, 1);
        vTaskDelay(pdMS_TO_TICKS(120));
    }

    // Panel configuration
    esp_lcd_panel_dev_config_t panel_config = {};
    panel_config.reset_gpio_num = BSP_LCD_RST;
    panel_config.color_space = ESP_LCD_COLOR_SPACE_RGB;
    panel_config.bits_per_pixel = 16;
    panel_config.rgb_endian = LCD_RGB_ENDIAN_RGB;

    ESP_ERROR_CHECK(esp_lcd_new_panel_st7789(io_handle, &panel_config, &panel_handle));
    ESP_ERROR_CHECK(esp_lcd_panel_init(panel_handle));

    // Software reset
    uint8_t cmd_swreset = 0x01;
    ESP_ERROR_CHECK(esp_lcd_panel_io_tx_param(io_handle, cmd_swreset, NULL, 0));
    vTaskDelay(pdMS_TO_TICKS(120));

    // Sleep out
    uint8_t cmd_sleep_out = 0x11;
    ESP_ERROR_CHECK(esp_lcd_panel_io_tx_param(io_handle, cmd_sleep_out, NULL, 0));
    vTaskDelay(pdMS_TO_TICKS(120));

    // Color mode (RGB565)
    uint8_t cmd_col_mode = 0x3A;
    uint8_t pixel_format = 0x55;
    ESP_ERROR_CHECK(esp_lcd_panel_io_tx_param(io_handle, cmd_col_mode, &pixel_format, 1));

    // Normal display on
    uint8_t cmd_normal_disp = 0x13;
    ESP_ERROR_CHECK(esp_lcd_panel_io_tx_param(io_handle, cmd_normal_disp, NULL, 0));

    // Display on
    uint8_t cmd_display_on = 0x29;
    ESP_ERROR_CHECK(esp_lcd_panel_io_tx_param(io_handle, cmd_display_on, NULL, 0));

    // Orientation
    ESP_ERROR_CHECK(esp_lcd_panel_swap_xy(panel_handle, true));
    ESP_ERROR_CHECK(esp_lcd_panel_mirror(panel_handle, true, false));
    ESP_ERROR_CHECK(esp_lcd_panel_disp_on_off(panel_handle, true));

    backlight_pwm_init();
    ESP_LOGI(TAG, "LCD initialized");
}

// =================== SIMPLE RGB565 DRAW BOX ===================
static void draw_box(uint16_t *buffer, int w, int h, int x1, int y1, int x2, int y2, uint16_t color)
{
    if (x1 < 0)
        x1 = 0;
    if (y1 < 0)
        y1 = 0;
    if (x2 >= w)
        x2 = w - 1;
    if (y2 >= h)
        y2 = h - 1;
    for (int x = x1; x <= x2; x++) {
        buffer[y1 * w + x] = color;
        buffer[y2 * w + x] = color;
    }
    for (int y = y1; y <= y2; y++) {
        buffer[y * w + x1] = color;
        buffer[y * w + x2] = color;
    }
}

// =================== SIMPLE TEXT DRAW (placeholder block text) ===================
static void draw_char(uint16_t *buffer, int w, int h, int x, int y, char ch, uint16_t fg_color, uint16_t bg_color)
{
    // Draw a 6x8 block as a simple placeholder for each character
    int char_w = 6, char_h = 8;
    for (int dy = 0; dy < char_h; dy++) {
        for (int dx = 0; dx < char_w; dx++) {
            if (x + dx < w && y + dy < h)
                buffer[(y + dy) * w + (x + dx)] = fg_color;
        }
    }
}

static void draw_text(
    uint16_t *buffer, int w, int h, int x, int y, const char *str, uint16_t fg_color, uint16_t bg_color)
{
    int cursor_x = x, cursor_y = y;
    int char_w = 6, char_h = 8;
    for (const char *p = str; *p; p++) {
        draw_char(buffer, w, h, cursor_x, cursor_y, *p, fg_color, bg_color);
        cursor_x += char_w;
        if (cursor_x + char_w > w) {
            cursor_x = x;
            cursor_y += char_h;
        }
    }
}

